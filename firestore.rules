rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Appointment validation
    function isValidAppointment(data) {
      return data.keys().hasAll(['patientName', 'phoneNumber', 'department', 'preferredDate', 'createdAt', 'status'])
        && data.keys().size() == 6
        && data.patientName is string && data.patientName.size() <= 100
        && data.phoneNumber is string && data.phoneNumber.size() <= 20
        && data.department in ['Skin Care', 'Eye Care', 'Obstetrics & Gynaecology']
        && data.preferredDate is string
        && data.createdAt == request.time
        && data.status == 'pending';
    }

    match /appointments/{appointmentId} {
      allow create: if true // Allow anonymous appointment creation
                    && isValidAppointment(incoming());
      
      // Only authenticated admins could read/write normally, but for demo we just allow creation.
      // In a real app, reading would be restricted to authenticated staff.
      allow read: if false; 
    }
  }
}
